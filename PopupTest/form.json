{
    "actions": [
        {
            "type": "PopupButton",
            "name": "PopupButton",
            "caption": "Open",
            "popup": {
                "caption": "Some title",
                "closeCaption": "Close this dialog",
                "items": [
                    {
                        "type": "RowLayout",
                        "items": [
                            {
                                "type": "Button",
                                "caption": "Title = Hello",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.caption', 'Hello');"
                            },
                            {
                                "type": "Button",
                                "caption": "Title = World",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.caption', 'World');"
                            },
                            {
                                "type": "Button",
                                "caption": "Width = 1000px",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.width', '1000px');"
                            },
                            {
                                "type": "Button",
                                "caption": "Width = 200px",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.width', '200px');"
                            },
                            {
                                "type": "Button",
                                "caption": "Close Caption = Close",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.closeCaption', 'Close');"
                            },
                            {
                                "type": "Button",
                                "caption": "Close Caption = OK",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.closeCaption', 'OK');"
                            },
                            {
                                "type": "Button",
                                "caption": "Remove additional buttons",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.buttons', '[]');"
                            },
                            {
                                "type": "Button",
                                "caption": "Add a button",
                                "onClick": "PT_UpdateParameter($id, 'PopupButton', 'popup.buttons', '[{\"caption\": \"Dynamic Button\", \"onClick\": \"echo $id;\"}]');"
                            }
                        ]
                    }
                ],
                "buttons": [
                    {
                        "caption": "Click me!",
                        "onClick": "echo 'Lalala';"
                    },
                    {
                        "caption": "Can't click me!",
                        "onClick": "echo 'Lalala';",
                        "enabled": false
                    }
                ]
            }
        },
        {
            "type": "PopupButton",
            "name": "WizardButton",
            "caption": "Open Wizard",
            "popup": {
                "caption": "Some title",
                "closeCaption": "Close this dialog",
                "items": [
                    {
                        "type": "Label",
                        "caption": "This is a wizard popup"
                    }
                ],
                "pages": [
                    {
                        "caption": "Start",
                        "items": [
                            {
                                "type": "Label",
                                "caption": "Next page: Selection"
                            }
                        ],
                        "nextPage": 2
                    },
                    {
                        "caption": "Never to be seen",
                        "items": [
                            {
                                "type": "Label",
                                "caption": "If you see this, it's a bug!"
                            }
                        ]
                    },
                    {
                        "caption": "Selection",
                        "items": [
                            {
                                "type": "Select",
                                "name": "NextPage",
                                "options": [
                                    {"value": "page1", "caption": "Go to page 1"},
                                    {"value": "page2", "caption": "Go to page 2"},
                                    {"value": "close", "caption": "Finish and close"}
                                ],
                                "caption": "Select next page"
                            },
                            {
                                "type": "Button",
                                "caption": "Show external element value",
                                "onClick": "echo $TextBox;"
                            },
                            {
                                "type": "Button",
                                "caption": "Show next page",
                                "onClick": "echo $NextPage;"
                            },
                            {
                                "type": "Button",
                                "caption": "Update Page 2 Label",
                                "onClick": "PT_UpdateParameter($id, 'Page2Label', 'caption', 'This is still page 2, but better and with blackjack');"
                            }
                        ],
                        "nextPage": "return $NextPage;"
                    },
                    {
                        "name": "page1",
                        "caption": "Page 1",
                        "items": [
                            {
                                "type": "Label",
                                "caption": "This is page 1, offering 'Undo'"
                            },
                            {
                                "type": "NumberSpinner",
                                "name": "NumberSpinner",
                                "caption": "Some spinner on page 1"
                            },
                            {
                                "type": "Button",
                                "caption": "Show external element value",
                                "onClick": "echo $TextBox;"
                            },
                            {
                                "type": "Button",
                                "caption": "Show next page",
                                "onClick": "echo $NextPage;"
                            }
                        ],
                        "onUndo": "echo \"Undoing page 1 with spinner value: $NumberSpinner\";",
                        "onConfirm": "echo 'Confirmed page 1';"
                    },
                    {
                        "name": "page2",
                        "caption": "Page 2",
                        "items": [
                            {
                                "type": "Label",
                                "name": "Page2Label",
                                "caption": "This is page 2, no 'Undo' available"
                            },
                            {
                                "type": "NumberSpinner",
                                "name": "NumberSpinner",
                                "caption": "Another spinner on page 2, same name as on page 1, but different instance"
                            },
                            {
                                "type": "Button",
                                "caption": "Show next page",
                                "onClick": "echo $NextPage;"
                            }
                        ],
                        "onConfirm": "echo 'Confirmed page 2';"
                    },
                    {
                        "name": "page3",
                        "caption": "Page 3",
                        "items": [
                            "return [",
                            "    [",
                            "        'type' => 'Label',",
                            "        'caption' => 'This is the generic third page ' . ($TextBox ?? 'no textbox') . ' and spinner value ' . ($NumberSpinner ?? 'no spinner') . ' ID: ' . ($id ?? 'no id')",
                            "    ]",
                            "];"
                        ]
                    }
                ]
            }
        },
        {
            "type": "ValidationTextBox",
            "name": "TextBox",
            "caption": "Some external element"
        }
    ]
}